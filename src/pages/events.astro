---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Events | Volute">
    <div class="page-header">
        <div class="header-text">
            <h1 class="page-title">Events</h1>
            <p class="page-subtitle">
                Manage and track your schedule with style
            </p>
        </div>
        <div class="actions">
            <button class="btn-primary" id="btn-new-event">
                <span class="btn-icon-wrapper">
                    <svg
                        width="20"
                        height="20"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"></path>
                    </svg>
                </span>
                New Event
            </button>
        </div>
    </div>

    <div class="events-board-container">
        <div class="events-list" id="events-list-container">
            <!-- Rendered via JS -->
            <div class="empty-state">
                <div class="spinner"></div>
                <p>Loading events...</p>
            </div>
        </div>
    </div>

    <dialog id="event-modal" class="modal-dialog glass-panel">
        <form id="event-form" class="modal-form">
            <div class="modal-header">
                <h2>Add New Event</h2>
                <button type="button" class="btn-close" id="close-modal-icon">
                    <svg
                        width="24"
                        height="24"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <div class="form-body">
                <div class="form-group">
                    <label for="event-title">Event Title</label>
                    <input
                        type="text"
                        id="event-title"
                        required
                        class="form-input"
                        placeholder="e.g. Weekly Team Sync"
                    />
                </div>

                <div class="form-group">
                    <label for="event-description">Description</label>
                    <textarea
                        id="event-description"
                        class="form-input"
                        placeholder="Add some details..."
                        rows="2"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="event-date">Date</label>
                        <input
                            type="date"
                            id="event-date"
                            required
                            class="form-input"
                        />
                    </div>

                    <div class="form-group">
                        <label for="event-time">Time</label>
                        <input
                            type="time"
                            id="event-time"
                            required
                            class="form-input"
                        />
                    </div>
                </div>

                <div class="form-group">
                    <label for="event-type">Event Type</label>
                    <div class="select-wrapper">
                        <select id="event-type" class="form-input">
                            <option value="meeting">Meeting</option>
                            <option value="milestone">Milestone</option>
                            <option value="review">Review</option>
                            <option value="other">Other</option>
                        </select>
                        <svg
                            class="select-icon"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" id="cancel-event"
                    >Cancel</button
                >
                <button type="submit" class="btn-primary">Save Event</button>
            </div>
        </form>
    </dialog>
</Layout>

<script>
    import { db } from "../lib/db";

    document.addEventListener("DOMContentLoaded", () => {
        const listContainer = document.getElementById("events-list-container");
        const modal = document.getElementById(
            "event-modal",
        ) as HTMLDialogElement;
        const btnNewEvent = document.getElementById("btn-new-event");
        const btnCancel = document.getElementById("cancel-event");
        const btnCloseIcon = document.getElementById("close-modal-icon");
        const form = document.getElementById("event-form") as HTMLFormElement;

        const getTypeColor = (type: string) => {
            switch (type.toLowerCase()) {
                case "meeting":
                    return "bg-blue-500/20 text-blue-400 border-blue-500/30";
                case "milestone":
                    return "bg-purple-500/20 text-purple-400 border-purple-500/30";
                case "review":
                    return "bg-emerald-500/20 text-emerald-400 border-emerald-500/30";
                default:
                    return "bg-gray-500/20 text-gray-400 border-gray-500/30";
            }
        };

        const getTypeIcon = (type: string) => {
            switch (type.toLowerCase()) {
                case "meeting":
                    return '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />';
                case "milestone":
                    return '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />';
                case "review":
                    return '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
                default:
                    return '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />';
            }
        };

        async function loadEvents() {
            if (!listContainer) return;
            const events = await db.events.toArray();

            // Sort by earliest date first
            events.sort(
                (a, b) =>
                    new Date(a.date).getTime() - new Date(b.date).getTime(),
            );

            if (events.length === 0) {
                listContainer.innerHTML = `
                    <div class="empty-state-visual">
                        <div class="empty-icon-wrapper">
                            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                <circle cx="12" cy="14" r="2" fill="currentColor" fill-opacity="0.2" />
                            </svg>
                        </div>
                        <h3>No events scheduled</h3>
                        <p>You don't have any events yet. Click 'New Event' to add one.</p>
                    </div>
                `;
                return;
            }

            listContainer.innerHTML = events
                .map((event) => {
                    const parts = event.date.split("-");
                    const d = new Date(
                        parseInt(parts[0]),
                        parseInt(parts[1]) - 1,
                        parseInt(parts[2]),
                    );
                    const day = d.getDate();
                    const month = d.toLocaleString("default", {
                        month: "short",
                    });
                    const typeStyle = getTypeColor(event.type);
                    const typeIcon = getTypeIcon(event.type);

                    return `
                    <div class="event-item group" data-event-id="${event.id}">
                        <div class="event-header-top">
                            <div class="event-type-badge ${typeStyle}">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    ${typeIcon}
                                </svg>
                                <span>${event.type}</span>
                            </div>
                            <button class="action-btn delete-event" data-id="${event.id}" title="Delete event">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>
                        
                        <div class="event-main-content">
                            <h3 class="event-title">${event.title}</h3>
                            ${event.description ? `<p class="event-description">${event.description}</p>` : ""}
                        </div>

                        <div class="event-footers">
                            <div class="event-meta-pill">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <span>${month} ${day}</span>
                            </div>
                            <div class="event-meta-pill">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>${event.time}</span>
                            </div>
                        </div>
                    </div>
                `;
                })
                .join("");

            // Attach delete listeners
            listContainer.querySelectorAll(".delete-event").forEach((btn) => {
                btn.addEventListener("click", async (e) => {
                    e.stopPropagation();
                    const btnEl = e.currentTarget as HTMLButtonElement;
                    const id = Number(btnEl.dataset.id);
                    if (id) {
                        btnEl.closest(".event-item")?.classList.add("removing");
                        setTimeout(async () => {
                            await db.events.delete(id);
                            loadEvents();
                        }, 300);
                    }
                });
            });

            // Attach edit listeners
            listContainer.querySelectorAll(".event-item").forEach((item) => {
                item.addEventListener("click", async (e) => {
                    const el = e.currentTarget as HTMLElement;
                    const id = Number(el.dataset.eventId);
                    if (!id) return;

                    const event = await db.events.get(id);
                    if (!event) return;

                    (
                        document.getElementById(
                            "event-title",
                        ) as HTMLInputElement
                    ).value = event.title;
                    (
                        document.getElementById(
                            "event-date",
                        ) as HTMLInputElement
                    ).value = event.date;
                    (
                        document.getElementById(
                            "event-time",
                        ) as HTMLInputElement
                    ).value = event.time;
                    (
                        document.getElementById(
                            "event-type",
                        ) as HTMLSelectElement
                    ).value = event.type;
                    (
                        document.getElementById(
                            "event-description",
                        ) as HTMLTextAreaElement
                    ).value = event.description || "";

                    form.dataset.editingId = String(id);
                    document.querySelector(".modal-header h2")!.textContent =
                        "Edit Event";
                    modal.showModal();
                });
            });
        }

        const closeModal = () => {
            modal.classList.add("closing");
            setTimeout(() => {
                modal.close();
                modal.classList.remove("closing");
            }, 250);
        };

        btnNewEvent?.addEventListener("click", () => {
            form.reset();
            delete form.dataset.editingId;
            document.querySelector(".modal-header h2")!.textContent =
                "Add New Event";
            // Default to current date/time to make form easier to fill
            const now = new Date();
            (document.getElementById("event-date") as HTMLInputElement).value =
                now.toISOString().split("T")[0];
            modal.showModal();
        });

        btnCancel?.addEventListener("click", closeModal);
        btnCloseIcon?.addEventListener("click", closeModal);

        modal?.addEventListener("click", (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const title = (
                document.getElementById("event-title") as HTMLInputElement
            ).value;
            const date = (
                document.getElementById("event-date") as HTMLInputElement
            ).value;
            const time = (
                document.getElementById("event-time") as HTMLInputElement
            ).value;
            const type = (
                document.getElementById("event-type") as HTMLSelectElement
            ).value;
            const description = (
                document.getElementById(
                    "event-description",
                ) as HTMLTextAreaElement
            ).value;

            const editingId = form.dataset.editingId;
            if (editingId) {
                await db.events.update(Number(editingId), {
                    title,
                    date,
                    time,
                    type,
                    description,
                });
            } else {
                await db.events.add({ title, date, time, type, description });
            }

            closeModal();
            loadEvents();
        });

        loadEvents();
    });
</script>

<style is:global>
    /* Utility Colors mapped to raw CSS for dynamic binding */
    .bg-blue-500\/20 {
        background-color: rgba(59, 130, 246, 0.15);
    }
    .text-blue-400 {
        color: #60a5fa;
    }
    .border-blue-500\/30 {
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .bg-purple-500\/20 {
        background-color: rgba(168, 85, 247, 0.15);
    }
    .text-purple-400 {
        color: #c084fc;
    }
    .border-purple-500\/30 {
        border: 1px solid rgba(168, 85, 247, 0.3);
    }

    .bg-emerald-500\/20 {
        background-color: rgba(16, 185, 129, 0.15);
    }
    .text-emerald-400 {
        color: #34d399;
    }
    .border-emerald-500\/30 {
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .bg-gray-500\/20 {
        background-color: rgba(107, 114, 128, 0.15);
    }
    .text-gray-400 {
        color: #9ca3af;
    }
    .border-gray-500\/30 {
        border: 1px solid rgba(107, 114, 128, 0.3);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        animation: fadeInDown 0.5s ease-out;
    }

    .header-text {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .page-title {
        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
    }

    .page-subtitle {
        color: var(--color-text-muted);
        font-size: 1.05rem;
        margin: 0;
    }

    .btn-primary {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: linear-gradient(
            135deg,
            var(--color-accent-primary) 0%,
            #4338ca 100%
        );
        color: white;
        padding: 0.6rem 1.25rem 0.6rem 0.6rem;
        border-radius: 9999px; /* Pill shape */
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 15px -3px rgba(79, 70, 229, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        cursor: pointer;
    }

    .btn-icon-wrapper {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
        padding: 0.4rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-primary:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 8px 25px -5px rgba(79, 70, 229, 0.5);
    }

    .btn-primary:active {
        transform: translateY(0) scale(0.98);
    }

    .glass-panel-pro {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .events-board-container {
        padding: 0.5rem 0;
        min-height: 400px;
    }

    .events-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        align-items: start;
    }

    .event-item {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        padding: 1.5rem;
        border-radius: 1.25rem;
        background: linear-gradient(
            135deg,
            rgba(30, 41, 59, 0.6) 0%,
            rgba(15, 23, 42, 0.4) 100%
        );
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-top: 4px solid var(--color-accent-primary, #6366f1);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.1),
            0 8px 20px -5px rgba(0, 0, 0, 0.2);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        animation: fadeIn 0.4s ease-out forwards;
        width: 100%;
        box-sizing: border-box;
        cursor: pointer;
    }

    .event-item::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            transparent 100%
        );
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .event-item:hover {
        transform: translateY(-5px);
        background: rgba(30, 41, 59, 0.7);
        border-color: rgba(99, 102, 241, 0.3);
        box-shadow:
            0 15px 35px -10px rgba(99, 102, 241, 0.2),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .event-item:hover::before {
        opacity: 1;
    }

    .event-item.removing {
        animation: fadeOut 0.3s ease-in forwards;
    }

    .event-header-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        width: 100%;
        z-index: 1;
    }

    .event-main-content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        z-index: 1;
        flex: 1;
    }

    .event-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        width: fit-content;
        box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.2);
    }

    .event-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 700;
        color: white;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .event-description {
        margin: 0;
        font-size: 0.95rem;
        color: var(--color-text-muted, #9ca3af);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .event-footers {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: auto;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        z-index: 1;
    }

    .event-meta-pill {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        font-weight: 600;
        background: rgba(0, 0, 0, 0.2);
        padding: 0.35rem 0.75rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .action-btn {
        opacity: 0;
        transform: scale(0.9);
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #ef4444;
        cursor: pointer;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .event-item:hover .action-btn {
        opacity: 1;
        transform: scale(1);
    }

    .action-btn:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
        border-color: rgba(239, 68, 68, 0.5);
        transform: scale(1.15) rotate(90deg);
        box-shadow: 0 0 15px rgba(239, 68, 68, 0.3);
    }

    .empty-state-visual {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
        animation: fadeIn 0.5s ease-out;
    }

    .empty-icon-wrapper {
        width: 96px;
        height: 96px;
        background: linear-gradient(
            135deg,
            rgba(99, 102, 241, 0.1) 0%,
            rgba(99, 102, 241, 0.02) 100%
        );
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-accent-primary);
        margin-bottom: 1.5rem;
        position: relative;
    }

    .empty-icon-wrapper::after {
        content: "";
        position: absolute;
        inset: -10px;
        border: 1px solid rgba(99, 102, 241, 0.1);
        border-radius: 50%;
        animation: pulse 2s infinite cubic-bezier(0.4, 0, 0.6, 1);
    }

    .empty-state-visual h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-text-primary);
        margin: 0 0 0.5rem 0;
    }

    .empty-state-visual p {
        color: var(--color-text-muted);
        max-width: 300px;
        margin: 0;
        line-height: 1.5;
    }

    /* Modal styles */
    .modal-dialog {
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        color: var(--color-text-primary);
        padding: 0;
        margin: auto;
        max-width: 480px;
        width: 90vw;
        box-shadow:
            0 25px 50px -12px rgba(0, 0, 0, 0.5),
            0 0 0 1px rgba(255, 255, 255, 0.05);
        opacity: 0;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); /* Bouncy enter */
    }

    .modal-dialog[open] {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    .modal-dialog.closing {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
        transition: all 0.2s ease-in;
    }

    .modal-dialog::backdrop {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .modal-dialog[open]::backdrop {
        opacity: 1;

---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Settings | Volute">
    <div class="settings-header">
        <div>
            <h1 class="page-title">Settings</h1>
            <p class="page-subtitle">
                Manage your account settings and preferences.
            </p>
        </div>
    </div>

    <div class="settings-grid">
        <Card title="Profile Settings" class="settings-card">
            <form id="profile-form" class="profile-form">
                <div class="form-group">
                    <label for="name" class="form-label">Name</label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="form-input"
                        placeholder="Jane Doe"
                        required
                    />
                </div>
                <div class="form-group">
                    <label for="email" class="form-label">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="form-input"
                        placeholder="jane@example.com"
                        required
                    />
                </div>
                <div class="form-group">
                    <label for="role" class="form-label">Role</label>
                    <input
                        type="text"
                        id="role"
                        name="role"
                        class="form-input"
                        placeholder="e.g. Administrator"
                        required
                    />
                </div>
                <div class="form-group">
                    <label for="avatarUrl" class="form-label">Avatar URL</label>
                    <input
                        type="url"
                        id="avatarUrl"
                        name="avatarUrl"
                        class="form-input"
                        placeholder="https://ui-avatars.com/api/?name=Jane+Doe"
                    />
                    <p class="form-help">
                        Leave blank to use an auto-generated avatar.
                    </p>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary" id="save-btn">
                        Save Profile
                    </button>
                    <span id="save-msg" class="save-msg"></span>
                </div>
            </form>
        </Card>

        <Card title="Preview" class="preview-card">
            <div class="profile-preview">
                <img
                    id="preview-avatar"
                    src="https://ui-avatars.com/api/?name=User&background=random"
                    alt="Avatar Preview"
                    class="preview-img"
                />
                <h3 id="preview-name" class="preview-name">User Name</h3>
                <p id="preview-role" class="preview-role">Role</p>
                <p id="preview-email" class="preview-email">
                    email@example.com
                </p>
            </div>
        </Card>
    </div>
</Layout>

<script>
    import { db } from "../lib/db";

    document.addEventListener("DOMContentLoaded", async () => {
        const form = document.getElementById("profile-form") as HTMLFormElement;
        const nameInput = document.getElementById("name") as HTMLInputElement;
        const emailInput = document.getElementById("email") as HTMLInputElement;
        const roleInput = document.getElementById("role") as HTMLInputElement;
        const avatarUrlInput = document.getElementById(
            "avatarUrl",
        ) as HTMLInputElement;
        const saveMsg = document.getElementById("save-msg") as HTMLSpanElement;

        const previewAvatar = document.getElementById(
            "preview-avatar",
        ) as HTMLImageElement;
        const previewName = document.getElementById("preview-name");
        const previewRole = document.getElementById("preview-role");
        const previewEmail = document.getElementById("preview-email");

        // Load existing profile
        const profile = await db.profile.get(1);
        if (profile) {
            nameInput.value = profile.name || "";
            emailInput.value = profile.email || "";
            roleInput.value = profile.role || "";
            avatarUrlInput.value = profile.avatarUrl || "";

            updatePreview(
                profile.name,
                profile.role,
                profile.email,
                profile.avatarUrl,
            );
        }

        // Handle live preview
        const inputs = [nameInput, emailInput, roleInput, avatarUrlInput];
        inputs.forEach((input) => {
            input.addEventListener("input", () => {
                const url =
                    avatarUrlInput.value ||
                    `https://ui-avatars.com/api/?name=${encodeURIComponent(nameInput.value || "User")}&background=random`;
                updatePreview(
                    nameInput.value || "User Name",
                    roleInput.value || "Role",
                    emailInput.value || "email@example.com",
                    url,
                );
            });
        });

        function updatePreview(
            name: string,
            role: string,
            email: string,
            avatarUrl: string,
        ) {
            if (previewName) previewName.textContent = name;
            if (previewRole) previewRole.textContent = role;
            if (previewEmail) previewEmail.textContent = email;
            if (previewAvatar) previewAvatar.src = avatarUrl;
        }

        // Handle form submission
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const btn = document.getElementById(
                "save-btn",
            ) as HTMLButtonElement;
            btn.disabled = true;
            btn.textContent = "Saving...";

            const name = nameInput.value;
            const email = emailInput.value;
            const role = roleInput.value;
            let avatarUrl = avatarUrlInput.value;

            if (!avatarUrl) {
                avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=random`;
                avatarUrlInput.value = avatarUrl;
            }

            try {
                await db.profile.put({
                    id: 1, // We only store one profile currently
                    name,
                    email,
                    role,
                    avatarUrl,
                });

                saveMsg.textContent = "Profile saved successfully!";
                saveMsg.className = "save-msg success";

                // Dispatch a custom event to update other components (like Sidebar)
                window.dispatchEvent(
                    new CustomEvent("profile-updated", {
                        detail: { name, email, role, avatarUrl },
                    }),
                );

                setTimeout(() => {
                    saveMsg.textContent = "";
                    saveMsg.className = "save-msg";
                }, 3000);
            } catch (error) {
                console.error(error);
                saveMsg.textContent = "Failed to save profile.";
                saveMsg.className = "save-msg error";
            } finally {
                btn.disabled = false;
                btn.textContent = "Save Profile";
            }
        });
    });
</script>

<style>
    .settings-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text-primary);
        margin-bottom: 0.5rem;
    }

    .page-subtitle {
        color: var(--color-text-muted);
    }

    .settings-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 1024px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }
    }

    .profile-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--color-text-secondary);
    }

    .form-input {
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(15, 23, 42, 0.5);
        color: var(--color-text-primary);
        font-family: inherit;
        font-size: 0.95rem;
        transition: all var(--transition-fast);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--color-accent-primary);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

    .form-help {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-top: -0.25rem;
    }

    .form-actions {
        margin-top: 1rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .btn-primary {
        background: var(--color-accent-primary);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 0.95rem;
        transition: all var(--transition-fast);
        box-shadow: 0 4px 6px -1px rgba(99, 102, 241, 0.4);
    }

    .btn-primary:hover:not(:disabled) {
        background: var(--color-accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.5);
    }

    .btn-primary:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .save-msg {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .save-msg.success {
        color: var(--color-success);
    }

    .save-msg.error {
        color: var(--color-danger);
    }

    .profile-preview {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 1.5rem 0;
    }

    .preview-img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid var(--color-bg-tertiary);
        margin-bottom: 1.5rem;
        object-fit: cover;
    }

    .preview-name {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--color-text-primary);
        margin-bottom: 0.25rem;
    }

    .preview-role {
        font-size: 0.95rem;
        color: var(--color-accent-primary);
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .preview-email {
        font-size: 0.9rem;
        color: var(--color-text-muted);
    }
</style>
